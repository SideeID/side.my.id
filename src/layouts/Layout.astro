---
import Footer from "@/components/Footer.astro";
import Navbar from "@/components/Navbar.astro";
import JsonLd from "@/components/JsonLd.astro";
import Analytics from "@vercel/analytics/astro";
import "@fontsource/geist-mono";
import "@fontsource/ibm-plex-serif";
import "@fontsource/noto-naskh-arabic";
import { ClientRouter } from "astro:transitions";
import { PUBLIC_GA_ID } from "@/utils/constants";
// import AskButton from "@/components/AskButton.astro";
import "../index.css";
import "katex/dist/katex.min.css";

type Props = {
  title: string;
  description: string;
  url: string;
  image?: string;
  schema?: Record<string, any> | null;
  articleMeta?: {
    type?: "article" | "website";
    author?: string;
    publishedTime?: string;
    modifiedTime?: string;
  };
};

const { 
  title, 
  description, 
  url, 
  image = "https://side.my.id/opengraph.png",
  schema,
  articleMeta = {}
} = Astro.props;
const currentPath = Astro.url.pathname;
const ogType = articleMeta?.type === "article" ? "article" : "website";
---

<!doctype html>
<html lang="en">
  <head>
    <title>{title}</title>
    <meta charset="UTF-8" />
    <meta name="title" content={title} />
    <meta name="description" content={description} />
    <meta property="og:type" content={ogType} />
    <meta property="og:url" content={url} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={image} />
    {articleMeta?.publishedTime && (
      <meta property="og:article:published_time" content={articleMeta.publishedTime} />
    )}
    {articleMeta?.modifiedTime && (
      <meta property="og:article:modified_time" content={articleMeta.modifiedTime} />
    )}
    {articleMeta?.author && (
      <meta property="og:article:author" content={articleMeta.author} />
    )}
    <meta property="twitter:card" content="summary_large_image" />
    <meta property="twitter:url" content={url} />
    <meta property="twitter:title" content={title} />
    <meta property="twitter:description" content={description} />
    <meta property="twitter:image" content={image} />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content={Astro.generator} />
    <link rel="canonical" href={url} />
    <link rel="sitemap" href="/sitemap.xml" />
    {schema && <JsonLd schema={schema} />}
    <ClientRouter />
  </head>
  <body class="w-full bg-monochrome-1 text-base-0">
    <div
      class="w-full prose prose-base container mx-auto max-w-3xl px-4 pt-24 prose-gray"
    >
      <main
        class="flex min-h-screen w-full relative items-start justify-center leading-[1.75] tracking-wide"
      >
        <slot />
      </main>
      <Footer />
    </div>
    <Navbar currentPath={currentPath} />
    <!-- <AskButton /> -->
    <Analytics />
    {PUBLIC_GA_ID && (
      <script define:vars={{ publicGaId: PUBLIC_GA_ID }}>
        import Analytics from 'analytics';
        import googleAnalytics from '@analytics/google-analytics';

        const analytics = Analytics({
          app: 'sideid',
          plugins: [
            googleAnalytics({
              measurementIds: [publicGaId],
            }),
          ],
        });

        analytics.page();
        window.addEventListener('astro:page-load', () => {
          analytics.page();
        });
      </script>
    )}
  </body>
</html>
