---
import Layout from "@/layouts/Layout.astro";
import { getCollection } from "astro:content";
import ReadingIndicator from "@/components/svelte/ReadingIndicator.svelte";
import { format } from "date-fns";
import { ArrowLeftIcon } from "lucide-svelte";
import { Image } from "astro:assets";
import {
  generateArticleSchema,
  generateBreadcrumbSchema,
  generateGraphSchema,
  formatSchemaDate,
} from "@/utils/schema-generators";

export async function getStaticPaths() {
  const notesEntries = await getCollection("notes");

  return notesEntries.map((item) => ({
    params: {
      slug: item.slug,
    },
    props: {
      item,
    },
  }));
}

const { item } = Astro.props;
const { Content, remarkPluginFrontmatter } = await item.render();
const articleUrl = `https://side.my.id/notes/${item.slug}`;

const articleSchema = generateArticleSchema({
  headline: item.data.title,
  description: item.data.description,
  url: articleUrl,
  datePublished: formatSchemaDate(item.data.created_at),
  author: {
    name: item.data.author,
    url: "https://side.my.id",
  },
  publisherName: "Dimas Fajar Katon Prayogo",
  publisherLogo: "https://side.my.id/opengraph.png",
  image: "https://side.my.id/opengraph.png",
});

const breadcrumbSchema = generateBreadcrumbSchema({
  items: [
    { name: "Home", url: "https://side.my.id" },
    { name: "Notes", url: "https://side.my.id/notes" },
    { name: item.data.title, url: articleUrl },
  ],
});

const schema = generateGraphSchema([articleSchema, breadcrumbSchema]);
---

<ReadingIndicator client:only="svelte" />
<Layout
  title={item.data.title}
  description={item.data.description}
  url={articleUrl}
  schema={schema}
  articleMeta={{
    type: "article",
    author: item.data.author,
    publishedTime: formatSchemaDate(item.data.created_at),
  }}
>
  <div class="w-full slide-enter-content text-justify">
    <a href="/notes" class="flex w-fit items-center justify-center">
      <button
        type="button"
        aria-label="back to notes"
        class="flex h-8 w-8 items-center justify-center rounded-full bg-monochrome-2"
      >
        <ArrowLeftIcon className="text-center" />
      </button>
    </a>
    <h1 class="mt-4">{item.data.title}</h1>
    <div class="flex w-full items-center space-x-2">
      <div class="rounded-full!">
        <Image
          src="/avatar.webp"
          alt="SideID"
          width={28}
          height={28}
          class="h-7 w-7 rounded-full"
          loading="eager"
        />
      </div>
      <span class="font-semibold"
        >{item.data.author}, {remarkPluginFrontmatter.minutesRead} / {
          format(item.data.created_at, "LLLL d, yyyy")
        }
      </span>
    </div>
    <!-- <p class="arabic-font text-right text-xl font-semibold">
      بِسْمِ اللَّهِ الرَّحْمَٰنِ الرَّحِيمِ
    </p> -->
    <Content />
  </div>
</Layout>
