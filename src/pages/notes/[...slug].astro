---
import Layout from "@/layouts/Layout.astro";
import Breadcrumb from "@/components/Breadcrumb.astro";
import { getCollection } from "astro:content";
import ReadingIndicator from "@/components/svelte/ReadingIndicator.svelte";
import { format } from "date-fns";
import { Image } from "astro:assets";
import {
  generateArticleSchema,
  generateBreadcrumbSchema,
  generateGraphSchema,
  formatSchemaDate,
} from "@/utils/schema-generators";
import { ROUTES, SITE_URL } from "@/utils/constants";

export async function getStaticPaths() {
  const notesEntries = await getCollection("notes");

  return notesEntries.map((item) => ({
    params: {
      slug: item.slug,
    },
    props: {
      item,
      allNotes: notesEntries,
    },
  }));
}

const { item, allNotes } = Astro.props;
const { Content, remarkPluginFrontmatter } = await item.render();
const articleUrl = `${SITE_URL}${ROUTES.note(item.slug)}`;

const relatedNotes = allNotes
  .filter(
    (note: typeof item) =>
      note.slug !== item.slug &&
      note.data.tags.some((tag: string) => item.data.tags.includes(tag))
  )
  .sort(
    (a: typeof item, b: typeof item) =>
      new Date(b.data.created_at).getTime() -
      new Date(a.data.created_at).getTime()
  )
  .slice(0, 3);

const articleSchema = generateArticleSchema({
  headline: item.data.title,
  description: item.data.description,
  url: articleUrl,
  datePublished: formatSchemaDate(item.data.created_at),
  author: {
    name: item.data.author,
    url: SITE_URL,
  },
  publisherName: "Dimas Fajar Katon Prayogo",
  publisherLogo: `${SITE_URL}/opengraph.png`,
  image: `${SITE_URL}/opengraph.png`,
});

const breadcrumbSchema = generateBreadcrumbSchema({
  items: [
    { name: "Home", url: SITE_URL },
    { name: "Notes", url: `${SITE_URL}${ROUTES.notes}` },
    { name: item.data.title, url: articleUrl },
  ],
});

const schema = generateGraphSchema([articleSchema, breadcrumbSchema]);
---

<ReadingIndicator client:only="svelte" />
<Layout
  title={item.data.title}
  description={item.data.description}
  schema={schema}
  articleMeta={{
    type: "article",
    author: item.data.author,
    publishedTime: formatSchemaDate(item.data.created_at),
  }}
>
  <div class="w-full slide-enter-content text-justify">
    <Breadcrumb
      items={[
        { label: "Home", href: ROUTES.home },
        { label: "Notes", href: ROUTES.notes },
        { label: item.data.title },
      ]}
    />

    <h1 class="mt-0">{item.data.title}</h1>

    <div class="flex w-full items-center space-x-2">
      <div class="rounded-full!">
        <Image
          src="/avatar.webp"
          alt="SideID"
          width={28}
          height={28}
          class="h-7 w-7 rounded-full"
          loading="eager"
        />
      </div>
      <span class="font-semibold"
        >{item.data.author}, {remarkPluginFrontmatter.minutesRead} / {
          format(item.data.created_at, "LLLL d, yyyy")
        }
      </span>
    </div>

    {
      item.data.tags.length > 0 && (
        <div class="not-prose flex flex-wrap gap-2 mt-3 mb-6">
          {item.data.tags.map((tag: string) => (
            <a
              href={ROUTES.tag(tag)}
              class="bg-monochrome-2 hover:bg-monochrome-3 transition-colors px-3 py-1 text-xs font-semibold rounded-md no-underline! text-base-0/80 hover:text-base-0"
            >
              #{tag}
            </a>
          ))}
        </div>
      )
    }

    <!-- <p class="arabic-font text-right text-xl font-semibold">
      بِسْمِ اللَّهِ الرَّحْمَٰنِ الرَّحِيمِ
    </p> -->
    <Content />

    {
      relatedNotes.length > 0 && (
        <section class="not-prose mt-12 pt-8 border-t border-monochrome-3">
          <h2 class="text-lg font-extrabold mb-4 text-base-0">Related Notes</h2>
          <div class="flex flex-col gap-3">
            {relatedNotes.map((note: typeof item) => (
              <a
                href={ROUTES.note(note.slug)}
                class="group flex flex-col gap-1 p-3 rounded-md bg-monochrome-1/70 hover:bg-monochrome-2/70 border-[0.5px] border-monochrome-3 transition-all no-underline!"
              >
                <span class="font-semibold text-base-0 text-sm group-hover:underline line-clamp-2">
                  {note.data.title}
                </span>
                <span class="text-xs text-base-0/50">
                  {format(note.data.created_at, "LLLL d, yyyy")}
                </span>
              </a>
            ))}
          </div>
          <div class="mt-4">
            <a
              href={ROUTES.notes}
              class="text-sm font-semibold text-base-0/60 hover:text-base-0 transition-colors no-underline!"
            >
              View all notes
            </a>
          </div>
        </section>
      )
    }
  </div>
</Layout>
