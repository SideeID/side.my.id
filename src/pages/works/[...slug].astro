---
import Layout from "@/layouts/Layout.astro";
import Breadcrumb from "@/components/Breadcrumb.astro";
import { getCollection } from "astro:content";
import ReadingIndicator from "@/components/svelte/ReadingIndicator.svelte";
import { Image } from "astro:assets";
import {
  generateArticleSchema,
  generateBreadcrumbSchema,
  generateGraphSchema,
  formatSchemaDate,
} from "@/utils/schema-generators";
import { ROUTES, SITE_URL } from "@/utils/constants";

export async function getStaticPaths() {
  const worksEntries = await getCollection("works");

  return worksEntries.map((item) => ({
    params: { slug: item.slug },
    props: {
      item,
      allWorks: worksEntries,
    },
  }));
}

const { item, allWorks } = Astro.props;
const { Content, remarkPluginFrontmatter } = await item.render();
const workUrl = `${SITE_URL}${ROUTES.work(item.slug)}`;

// Related works: share at least 1 stack item, excluding current
const relatedWorks = allWorks
  .filter(
    (work: typeof item) =>
      work.slug !== item.slug &&
      (work.data.stack ?? []).some((s: string) =>
        (item.data.stack ?? []).includes(s)
      )
  )
  .sort(
    (a: typeof item, b: typeof item) =>
      new Date(b.data.date).getTime() - new Date(a.data.date).getTime()
  )
  .slice(0, 3);

const articleSchema = generateArticleSchema({
  headline: item.data.title,
  description: item.data.description,
  url: workUrl,
  datePublished: formatSchemaDate(item.data.date),
  author: {
    name: item.data.author,
    url: SITE_URL,
  },
  publisherName: "Dimas Fajar Katon Prayogo",
  publisherLogo: `${SITE_URL}/opengraph.png`,
  image: item.data.thumbnail || `${SITE_URL}/opengraph.png`,
});

const breadcrumbSchema = generateBreadcrumbSchema({
  items: [
    { name: "Home", url: SITE_URL },
    { name: "Works", url: `${SITE_URL}${ROUTES.works}` },
    { name: item.data.title, url: workUrl },
  ],
});

const schema = generateGraphSchema([articleSchema, breadcrumbSchema]);
---

<ReadingIndicator client:only="svelte" />
<Layout
  title={item.data.title}
  description={item.data.description}
  schema={schema}
  articleMeta={{
    type: "article",
    author: item.data.author,
    publishedTime: formatSchemaDate(item.data.date),
  }}
>
  <div class="w-full text-justify slide-enter-content">
    <Breadcrumb
      items={[
        { label: "Home", href: ROUTES.home },
        { label: "Works", href: ROUTES.works },
        { label: item.data.title },
      ]}
    />

    <h1 class="mt-0">{item.data.title}</h1>

    <div class="flex w-full items-center space-x-2">
      <div class="rounded-full!">
        <Image
          src="/avatar.webp"
          alt="SideID"
          width={28}
          height={28}
          class="h-7 w-7 rounded-full"
          loading="eager"
        />
      </div>
      <span class="font-bold"
        >{item.data.author}, {remarkPluginFrontmatter.minutesRead}.
      </span>{" "}
      <div class="flex items-center justify-center space-x-1.5 font-bold">
        {
          item.data.preview ? (
            <>
              <a
                href={item.data.preview}
                target="_blank"
                rel="noopener noreferrer"
              >
                Preview
              </a>
              <span> / </span>
            </>
          ) : null
        }
        {
          item.data.repo ? (
            <a href={item.data.repo} target="_blank" rel="noopener noreferrer">
              Source
            </a>
          ) : null
        }
      </div>
    </div>

    {
      item.data.stack && item.data.stack.length > 0 && (
        <div class="not-prose flex flex-wrap gap-2 mt-3 mb-6">
          {item.data.stack.map((tech: string) => (
            <a
              href={ROUTES.tag(tech.toLowerCase())}
              class="bg-monochrome-2 hover:bg-monochrome-3 transition-colors px-3 py-1 text-xs font-semibold rounded-md no-underline! text-base-0/80 hover:text-base-0"
            >
              {tech}
            </a>
          ))}
        </div>
      )
    }

    <!-- <p class="arabic-font text-right text-xl font-bold">
      بِسْمِ اللَّهِ الرَّحْمَٰنِ الرَّحِيمِ
    </p> -->
    <Content />

    {
      relatedWorks.length > 0 && (
        <section class="not-prose mt-12 pt-8 border-t border-monochrome-3">
          <h2 class="text-lg font-extrabold mb-4 text-base-0">Related Works</h2>
          <div class="flex flex-col gap-3">
            {relatedWorks.map((work: typeof item) => (
              <a
                href={ROUTES.work(work.slug)}
                class="group flex items-center gap-3 p-3 rounded-md bg-monochrome-1/70 hover:bg-monochrome-2/70 border-[0.5px] border-monochrome-3 transition-all no-underline!"
              >
                <div class="flex flex-col gap-1 min-w-0">
                  <span class="font-semibold text-base-0 text-sm group-hover:underline line-clamp-2 leading-snug">
                    {work.data.title}
                  </span>
                  <div class="flex flex-wrap gap-1 mt-0.5">
                    {(work.data.stack ?? [])
                      .filter((s: string) =>
                        (item.data.stack ?? []).includes(s)
                      )
                      .slice(0, 3)
                      .map((s: string) => (
                        <span class="text-xs text-base-0/50">{s}</span>
                      ))}
                  </div>
                </div>
              </a>
            ))}
          </div>
          <div class="mt-4">
            <a
              href={ROUTES.works}
              class="text-sm font-semibold text-base-0/60 hover:text-base-0 transition-colors no-underline!"
            >
              View all works
            </a>
          </div>
        </section>
      )
    }
  </div>
</Layout>
