---
import Card from "@/components/Card.astro";
import Breadcrumb from "@/components/Breadcrumb.astro";
import ReadingIndicator from "@/components/svelte/ReadingIndicator.svelte";
import Layout from "@/layouts/Layout.astro";
import { getCollection } from "astro:content";
import { ROUTES } from "@/utils/constants";

export async function getStaticPaths() {
  const [notesEntries, worksEntries] = await Promise.all([
    getCollection("notes"),
    getCollection("works"),
  ]);

  // Normalisasi semua ke lowercase agar "Docker" == "docker"
  const allTags = [
    ...new Set([
      ...notesEntries.flatMap((item) =>
        item.data.tags.map((t: string) => t.toLowerCase())
      ),
      ...worksEntries.flatMap((item) =>
        (item.data.stack ?? []).map((s: string) => s.toLowerCase())
      ),
    ]),
  ].sort((a, b) => a.localeCompare(b));

  return allTags.map((tag) => ({
    params: { slug: tag },
    props: {
      tag,
      notes: notesEntries
        .filter((item) =>
          item.data.tags.map((t: string) => t.toLowerCase()).includes(tag)
        )
        .sort(
          (a, b) =>
            new Date(b.data.created_at).getTime() -
            new Date(a.data.created_at).getTime()
        ),
    },
  }));
}

const { tag, notes } = Astro.props;
---

<ReadingIndicator client:only="svelte" />
<Layout
  title={`Notes with tag #${tag}`}
  description={`Browse all notes tagged with #${tag}.`}
>
  <div
    class:list={[
      "flex w-full flex-col items-start justify-start",
      "md:text-start",
    ]}
  >
    <section class="w-full">
      <Breadcrumb
        items={[
          { label: "Home", href: ROUTES.home },
          { label: "Tags", href: ROUTES.tags },
          { label: `#${tag}` },
        ]}
      />
      <h1 class="mb-0">./tags/{tag}</h1>
      <div class="slide-enter-content">
        <p id="description" class="mb-0 text-justify">
          {
            notes.length > 0
              ? `${notes.length} note${notes.length !== 1 ? "s" : ""} tagged with `
              : "No notes tagged with "
          }
          <strong>#{tag}</strong>.
        </p>
      </div>
    </section>
    {
      notes.length > 0 && (
        <section class="mt-8 w-full">
          <div class="grid w-full grid-cols-1 grid-rows-1 gap-4 sm:grid-cols-2 slide-enter-content">
            {notes.map((item: any) => (
              <Card
                title={item.data.title}
                description={item.data.description}
                type="notes"
                slug={item.slug}
                createdAt={item.data.created_at}
              />
            ))}
          </div>
        </section>
      )
    }
  </div>
</Layout>
