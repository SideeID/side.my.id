---
import Card from "@/components/Card.astro";
import Layout from "@/layouts/Layout.astro";
import { Image } from "astro:assets";
import { getCollection } from "astro:content";
import {
  generatePersonSchema,
  generateOrganizationSchema,
  generateGraphSchema,
} from "@/utils/schema-generators";
import { ROUTES } from "@/utils/constants";

const [notesList, worksList] = await Promise.all([
  await getCollection("notes"),
  await getCollection("works"),
]);

const personSchema = generatePersonSchema({
  name: "Dimas Fajar Katon Prayogo",
  url: "https://side.my.id",
  jobTitle: "DevOps Engineer & Fullstack Web Developer",
  description:
    "Developer based in Indonesia focused on server and infrastructure (DevOps), web technologies, and automation. Currently learning security and Go.",
  image: "https://avatars.githubusercontent.com/u/132200554?v=4",
  email: "dimas@side.my.id",
  sameAs: [
    "https://github.com/SideeID",
    "https://linkedin.com/in/dimas-fajar-katon-prayogo",
    "https://twitter.com/sideid_",
  ],
});

const organizationSchema = generateOrganizationSchema({
  name: "Dimas Fajar Katon Prayogo",
  url: "https://side.my.id",
  description: "Personal portfolio and blog about web development and DevOps",
  logo: "https://side.my.id/opengraph.png",
  sameAs: [
    "https://github.com/SideeID",
    "https://linkedin.com/in/dimas-fajar-katon-prayogo",
    "https://twitter.com/sideid_",
  ],
});

const schema = generateGraphSchema([personSchema, organizationSchema]);
---

<Layout
  title="Dimas Fajar Katon Prayogo"
  description="Javascript / Typescript Developer based in Indonesia. Focused on server and infrastructure (DevOps), security, Go, and automation."
  schema={schema}
>
  <div
    class:list={[
      "flex w-full flex-col items-start justify-start",
      "md:text-start",
    ]}
  >
    <section class="w-full">
      <div
        class="slide-enter-content flex w-fit space-x-0 md:space-x-4 relative justify-start items-start"
      >
        <div
          class="bg-monochrome-3 hidden md:block -rotate-3! p-1.5 rounded-md w-125 h-fit"
        >
          <Image
          src="https://avatars.githubusercontent.com/u/132200554?v=4"
          alt="Github Profile"
          width={500}
          height={500}
          quality={100}
          draggable={false}
          class="photos w-36! my-0! border-none! object-cover"
          loading="eager"
        />
        </div>
        <div>
          <h2 data-cy="name" class="mb-0! mt-0!">
            Dimas Fajar Katon Prayogo [<abbr title="He/Him">he/him</abbr>]
          </h2>
            <p data-cy="description" class="mb-0! mt-2 text-justify text-base-0">
            Konnichiwa! I'm Dimas. You can call me <b>Dimas/Dim/Mas</b>. I'm a Developer based in
            Indonesia, also amateur badminton player in my free time. Day-to-day,
            I mostly work on server and infrastructure (DevOps), and I'm currently learning security,
            Go, and automation.
            </p>
        </div>
      </div>
    </section>
    <section data-cy="experience" class="mt-8 w-full slide-enter-content">
      <h2 class="mb-6 mt-0 font-extrabold">Experience</h2>
      <div class="space-y-5 slide-enter-content">
        <div>
          <div
            class="flex w-full flex-col items-start justify-start sm:flex-row sm:items-center sm:justify-between"
          >
            <h3 class="mb-0 mt-0">FEHA</h3>
            <span class="mt-1.5 rounded-xs text-sm font-semibold sm:mt-0"
              >Mar 2026 - Present</span
            >
          </div>
          <p class="mb-0 mt-3 sm:mt-1 font-semibold">DevOps Engineer</p>
          <ul class="list-disc pl-5 mt-2 text-sm space-y-1">
            <li>Designing and improving system infrastructure to make deployments faster and more reliable</li>
            <li>Building and maintaining CI/CD pipelines that take the pain out of deployment processes</li>
            <li>Automating infrastructure tasks to eliminate repetitive work and reduce human error</li>
          </ul>
        </div>
        <div>
          <div
            class="flex w-full flex-col items-start justify-start sm:flex-row sm:items-center sm:justify-between"
          >
            <h3 class="mb-0 mt-0">PT Multi Spunindo Jaya Tbk - Internship</h3>
            <span class="mt-1.5 rounded-xs text-sm font-semibold sm:mt-0"
              >Dec 2025 - Feb 2026</span
            >
          </div>
          <p class="mb-0 mt-3 sm:mt-1 font-semibold">Full Stack Engineer</p>
          <ul class="list-disc pl-5 mt-2 text-sm space-y-1">
            <li>Built full stack features for internal apps—everything from database design to UI</li>
            <li>Worked across the entire stack to solve real business problems for the company</li>
            <li>Fixed bugs, improved performance, and made sure internal tools actually work when people need them</li>
          </ul>
        </div>
        <div>
          <div
            class="flex w-full flex-col items-start justify-start sm:flex-row sm:items-center sm:justify-between"
            >
            <h3 class="mb-0 mt-0">Inagata Technosmith - Freelance</h3>
            <span class="mt-1.5 rounded-xs text-sm font-semibold sm:mt-0"
              >Aug 2024 - Dec 2025</span
            >
            </div>
            <p class="mb-0 mt-3 sm:mt-1 font-semibold">Backend Developer</p>
            <ul class="list-disc pl-5 mt-2 text-sm space-y-1">
            <li>Developed and maintained large-scale applications with Laravel—everything from API to database optimization</li>
            <li>Worked on the annual performance evaluation system for the Ministry of Religious Affairs (handling thousands of evaluations)</li>
            <li>Implemented security features that actually keep user data safe</li>
            <li>Managed servers via SSH, handled deployments, and made sure apps stayed up and running</li>
            </ul>
        </div>
        <div>
          <div
            class="flex w-full flex-col items-start justify-start sm:flex-row sm:items-center sm:justify-between"
          >
            <h3 class="mb-0 mt-0">Entercode - Freelance</h3>
            <span class="mt-1.5 rounded-xs text-sm font-semibold sm:mt-0"
              >Nov 2024 - Apr 2025</span
            >
          </div>
          <p class="mb-0 mt-3 sm:mt-1 font-semibold">Fullstack Web Developer</p>
          <ul class="list-disc pl-5 mt-2 text-sm space-y-1">
            <li>Developed web applications using modern tech stacks and best practices</li>
            <li>Worked with teams across design and product to ship quality software</li>
            <li>Built interfaces that look good and actually perform well for end users</li>
          </ul>
        </div>
        <div>
          <div
            class="flex w-full flex-col items-start justify-start sm:flex-row sm:items-center sm:justify-between"
          >
            <h3 class="mb-0 mt-0">Independent Freelance</h3>
            <span class="mt-1.5 rounded-xs text-sm font-semibold sm:mt-0"
              >2023 - Present</span
            >
          </div>
          <p class="mb-0 mt-3 sm:mt-1 font-semibold">Fullstack Web Developer</p>
          <ul class="list-disc pl-5 mt-2 text-sm space-y-1">
            <li>Consulted with clients to understand their needs, then built custom solutions that actually solve their problems</li>
            <li>Managed projects from start to finish—requirements gathering, development, testing, and deployment</li>
            <li>Continuously learned new frameworks and technologies to deliver better solutions</li>
          </ul>
        </div>
      </div>
    </section>
    <section data-cy="featured-works" class="mt-8 w-full slide-enter-content">
      <h2 class="mt-0 mb-6 font-extrabold">Featured Works</h2>
      <div
        class="grid w-full grid-cols-1 grid-rows-1 gap-4 sm:grid-cols-2 slide-enter-content"
      >
        {
          worksList
            .sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime())
            .slice(0, 4)
            .map((item) => (
              <Card
                title={item.data.title}
                description={item.data.description}
                thumbnail={item.data.thumbnail}
                type="works"
                slug={item.slug}
              />
            ))
        }
      </div>
      <div class="flex justify-end mt-3">
        <a
          href={ROUTES.works}
          class="text-sm font-semibold opacity-60 hover:opacity-100 transition-opacity no-underline! flex items-center gap-1"
        >
          See all works <span aria-hidden="true">→</span>
        </a>
      </div>
    </section>
    <section data-cy="featured-notes" class="mt-8 w-full">
      <h2 class="mt-0 mb-6 font-extrabold">Featured Notes</h2>
      <div class="grid w-full grid-cols-1 grid-rows-1 gap-4 sm:grid-cols-2">
        {
          notesList
            .sort(
              (a, b) =>
                new Date(b.data.created_at).getTime() -
                new Date(a.data.created_at).getTime()
            )
            .slice(0, 4)
            .map((item) => (
              <Card
                title={item.data.title}
                description={item.data.description}
                slug={item.slug}
                createdAt={item.data.created_at}
                type="notes"
              />
            ))
        }
      </div>
      <div class="flex justify-end mt-3">
        <a
          href={ROUTES.notes}
          class="text-sm font-semibold opacity-60 hover:opacity-100 transition-opacity no-underline! flex items-center gap-1"
        >
          See all notes <span aria-hidden="true">→</span>
        </a>
      </div>
    </section>
  </div>
</Layout>
